# See README for more info on these parameters.

# Always required.
ETHERSCAN_API_KEY=yourEtherscanApiKey  # Single API key for all chains via Etherscan v2 API
MAINNET_RPC_URL=yourMainnetRpcUrl  # Required for cross-chain functionality  
ARBITRUM_RPC_URL=yourArbitrumRpcUrl  # Required for cross-chain functionality
TENDERLY_ACCESS_TOKEN=yourTenderlyAccessToken
TENDERLY_USER=yourTenderlyOrgOrMeIfPersonal
TENDERLY_PROJECT_SLUG=yourTenderlyProjectSlug

# Only needed for GitHub Actions, or simulating all proposals locally.
DAO_NAME=Uniswap
GOVERNOR_ADDRESS=0x408ED6354d4973f66138C91495F2f2FCbd8724C3

# Optional: required for `bun upload --publish` to Vercel
# If both names are set, VERCEL_* takes precedence over SEATBELT_VERCEL_*.
VERCEL_TOKEN=yourVercelToken
VERCEL_PROJECT_ID=yourVercelProjectId
VERCEL_ORG_ID=yourVercelOrgOrTeamId
SEATBELT_VERCEL_TOKEN=
SEATBELT_VERCEL_PROJECT_ID=
SEATBELT_VERCEL_ORG_ID=

CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome # Optional, only needed if you aren't using the default Chrome path.

# Slither configuration
# Set to true to run Slither on unverified contracts (not recommended for security)
# Can also use --allow-unverified-slither CLI flag
SLITHER_ALLOW_UNVERIFIED=false
